@model FrontendAdministrativo.Models.ViewModels.EstadoServiciosViewModel

@{
    ViewData["Title"] = "Estado de servicios";
}

<style>
    .servicios-encabezado {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
    }

        .servicios-encabezado h2 {
            margin: 0;
            color: #102a43;
            font-weight: 700;
        }

        .servicios-encabezado p {
            margin: 5px 0 0;
            color: #6b7c93;
        }

    .fecha-consulta {
        color: #6b7c93;
        font-size: 14px;
    }

    .servicios-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .servicio-card {
        background: white;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 4px 18px rgba(16, 42, 67, 0.09);
    }

    .servicio-superior {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 15px;
    }

    .servicio-nombre {
        color: #102a43;
        font-size: 20px;
        font-weight: 700;
    }

    .servicio-tecnologia {
        margin-top: 5px;
        color: #6b7c93;
        font-size: 14px;
    }

    .servicio-estado {
        padding: 7px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
    }

    .disponible {
        background: #d8f3df;
        color: #157347;
    }

    .no-disponible {
        background: #f8d7da;
        color: #b02a37;
    }

    .no-configurado {
        background: #fff3cd;
        color: #856404;
    }

    .servicio-url {
        margin-top: 22px;
        padding: 14px;
        background: #f7f9fc;
        border-radius: 9px;
        overflow-wrap: anywhere;
    }

        .servicio-url span {
            display: block;
            margin-bottom: 4px;
            color: #6b7c93;
            font-size: 12px;
        }

        .servicio-url strong {
            color: #102a43;
            font-size: 14px;
        }

    .servicios-acciones {
        margin-top: 24px;
        display: flex;
        justify-content: flex-end;
    }

    @@media (max-width: 800px) {
        .servicios-grid {
            grid-template-columns: 1fr;
        }

        .servicios-encabezado {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="servicios-encabezado">
    <div>
        <h2>Estado de los servicios</h2>
        <p>
            Verifica la disponibilidad de las APIs del proyecto.
        </p>
    </div>

    <div class="fecha-consulta">
        Última consulta:
        @Model.FechaConsulta.ToString("dd/MM/yyyy HH:mm:ss")
    </div>
</div>

<div class="servicios-grid">

    @foreach (var servicio in Model.Servicios)
    {
        string claseEstado;

        if (!servicio.Configurado)
        {
            claseEstado = "no-configurado";
        }
        else if (servicio.Disponible)
        {
            claseEstado = "disponible";
        }
        else
        {
            claseEstado = "no-disponible";
        }

        <div class="servicio-card">

            <div class="servicio-superior">

                <div>
                    <div class="servicio-nombre">
                        @servicio.Nombre
                    </div>

                    <div class="servicio-tecnologia">
                        @servicio.Tecnologia
                    </div>
                </div>

                <span class="servicio-estado @claseEstado">
                    @servicio.Estado
                </span>

            </div>

            <div class="servicio-url">
                <span>Dirección configurada</span>

                <strong>
                    @(string.IsNullOrWhiteSpace(servicio.Url)
                        ? "No configurada"
                        : servicio.Url)
                </strong>
            </div>

        </div>
    }

</div>

<div class="servicios-acciones">
    <a asp-controller="EstadoServicios"
       asp-action="Index"
       class="btn btn-primary">
        Actualizar estado
    </a>
</div>