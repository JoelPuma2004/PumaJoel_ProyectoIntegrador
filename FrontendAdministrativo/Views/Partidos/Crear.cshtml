@model FrontendAdministrativo.Models.ViewModels.PartidoFormViewModel

@{
    ViewData["Title"] = "Nuevo partido";
}

<div class="page-header">
    <div>
        <h2>Nuevo partido</h2>

        <p>
            Registre un partido real en el Servicio de Estadísticas.
        </p>
    </div>

    <a asp-controller="Partidos"
       asp-action="Index"
       class="btn btn-outline-secondary">
        Volver
    </a>
</div>

@{
    bool faltanCatalogos =
        !Model.CatalogosDisponibles;
}

@if (faltanCatalogos)
{
    <div class="alert alert-danger">
        No fue posible cargar selecciones y sedes desde la API.
        La creación permanece deshabilitada y no se usarán datos de respaldo.
    </div>
}

<div class="alert alert-info">
    Equipo 1 y Equipo 2 indican el orden en el marcador.
    No significan que uno de los equipos juegue realmente
    como local o visitante.
</div>

@if (!string.IsNullOrWhiteSpace(Model.MensajeClasificacion))
{
    <div class="alert @(Model.PuedeCrearPartido ? "alert-success" : "alert-warning")">
        @Model.MensajeClasificacion
    </div>
}

<div class="panel-card">

    <form asp-controller="Partidos"
          asp-action="Crear"
          method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger">
        </div>

        <div class="row g-3">

            <div class="col-md-4">

                <label asp-for="NumeroPartidoFifa"
                       class="form-label">
                </label>

                <input asp-for="NumeroPartidoFifa"
                       class="form-control"
                       type="number"
                       min="89"
                       max="104"
                       readonly />

                <small class="text-muted">
                    Se asigna el siguiente número libre desde octavos hasta la final (89 a 104).
                </small>

                <span asp-validation-for="NumeroPartidoFifa"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-4">

                <label class="form-label">
                    Fase
                </label>

                <input asp-for="Fase"
                       type="hidden" />

                <input id="FaseTexto"
                       class="form-control"
                       type="text"
                       readonly />

                <small class="text-muted">
                    La fase se calcula automáticamente según el número FIFA.
                </small>

                <span asp-validation-for="Fase"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-4">

                <label asp-for="GrupoId"
                       class="form-label">
                </label>

                <select asp-for="GrupoId"
                        class="form-select">

                    <option value="">
                        No aplica
                    </option>

                    @foreach (var grupo in Model.Grupos)
                    {
                        <option value="@grupo.Id">
                            @grupo.Nombre
                        </option>
                    }

                </select>

                <small id="GrupoAyuda"
                       class="text-muted">
                </small>

                <span asp-validation-for="GrupoId"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-6">

                <label asp-for="SeleccionLocalId"
                       class="form-label">
                </label>

                <select asp-for="SeleccionLocalId"
                        class="form-select">

                    <option value="">
                        Seleccione el Equipo 1
                    </option>

                    @foreach (var seleccion in Model.SeleccionesLocalDisponibles)
                    {
                        <option value="@seleccion.Id">
                            @seleccion.Nombre
                            (@seleccion.Grupo)
                        </option>
                    }

                </select>

                <span asp-validation-for="SeleccionLocalId"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-6">

                <label asp-for="SeleccionVisitanteId"
                       class="form-label">
                </label>

                <select asp-for="SeleccionVisitanteId"
                        class="form-select">

                    <option value="">
                        Seleccione el Equipo 2
                    </option>

                    @foreach (var seleccion in Model.SeleccionesVisitanteDisponibles)
                    {
                        <option value="@seleccion.Id">
                            @seleccion.Nombre
                            (@seleccion.Grupo)
                        </option>
                    }

                </select>

                <span asp-validation-for="SeleccionVisitanteId"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-6">

                <label asp-for="FechaHora"
                       class="form-label">
                </label>

                <input asp-for="FechaHora"
                       type="datetime-local"
                       asp-format="{0:yyyy-MM-ddTHH:mm}"
                       class="form-control" />

                <span asp-validation-for="FechaHora"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-6">

                <label asp-for="SedeId"
                       class="form-label">
                </label>

                <select asp-for="SedeId"
                        class="form-select">

                    <option value="">
                        Seleccione una sede
                    </option>

                    @foreach (var sede in Model.Sedes)
                    {
                        <option value="@sede.Id">
                            @sede.Nombre - @sede.Ciudad
                        </option>
                    }

                </select>

                <span asp-validation-for="SedeId"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-4">

                <label asp-for="CuotaLocal"
                       class="form-label">
                </label>

                <input asp-for="CuotaLocal"
                       class="form-control"
                       type="number"
                       min="1"
                       step="0.01" />

                <span asp-validation-for="CuotaLocal"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-4">

                <label asp-for="CuotaEmpate"
                       class="form-label">
                </label>

                <input asp-for="CuotaEmpate"
                       class="form-control"
                       type="number"
                       min="1"
                       step="0.01" />

                <span asp-validation-for="CuotaEmpate"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-4">

                <label asp-for="CuotaVisitante"
                       class="form-label">
                </label>

                <input asp-for="CuotaVisitante"
                       class="form-control"
                       type="number"
                       min="1"
                       step="0.01" />

                <span asp-validation-for="CuotaVisitante"
                      class="text-danger">
                </span>

            </div>

        </div>

        <div class="form-actions mt-4">

            <a asp-controller="Partidos"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Cancelar
            </a>

            @if (faltanCatalogos ||
                 !Model.PuedeCrearPartido)
            {
                <button type="button"
                        class="btn btn-primary"
                        disabled>
                    Guardar partido real
                </button>
            }
            else
            {
                <button type="submit"
                        class="btn btn-primary">
                    Guardar partido real
                </button>
            }

        </div>

    </form>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function() {

            const numeroInput =
                document.getElementById("NumeroPartidoFifa");

            const faseInput =
                document.getElementById("Fase");

            const faseTexto =
                document.getElementById("FaseTexto");

            const grupoSelect =
                document.getElementById("GrupoId");

            const grupoAyuda =
                document.getElementById("GrupoAyuda");

            function obtenerFase(numero) {
                if (numero >= 89 && numero <= 96) {
                    return {
                        codigo: "OCTAVOS",
                        texto: "Octavos de final"
                    };
                }

                if (numero >= 97 && numero <= 100) {
                    return {
                        codigo: "CUARTOS",
                        texto: "Cuartos de final"
                    };
                }

                if (numero >= 101 && numero <= 102) {
                    return {
                        codigo: "SEMIFINAL",
                        texto: "Semifinal"
                    };
                }

                if (numero === 103) {
                    return {
                        codigo: "TERCER_PUESTO",
                        texto: "Tercer puesto"
                    };
                }

                if (numero === 104) {
                    return {
                        codigo: "FINAL",
                        texto: "Final"
                    };
                }

                return {
                    codigo: "",
                    texto: "Número no válido"
                };
            }

            function actualizarFormulario() {

                const numero =
                    Number(numeroInput.value);

                const fase =
                    obtenerFase(numero);

                faseInput.value =
                    fase.codigo;

                faseTexto.value =
                    fase.texto;

                grupoSelect.value = "";
                grupoSelect.disabled = true;
                grupoAyuda.textContent =
                    "No aplica en fases eliminatorias.";
            }

            numeroInput.addEventListener(
                "input",
                actualizarFormulario);

            actualizarFormulario();
        });
    </script>
}