@model FrontendAdministrativo.Models.PartidoDto

@{
    ViewData["Title"] = "Detalle del partido";

    string claseEstado = Model.Estado switch
    {
        "FINALIZADO" => "estado-finalizado",
        "EN JUEGO" => "estado-juego",
        _ => "estado-programado"
    };

    bool tieneMarcador =
        Model.GolesLocal.HasValue &&
        Model.GolesVisitante.HasValue;
}

<style>
    .detalle-contenedor {
        max-width: 950px;
        margin: 0 auto;
    }

    .detalle-encabezado {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 22px;
    }

        .detalle-encabezado h2 {
            margin: 0;
            color: #102a43;
            font-weight: 700;
        }

        .detalle-encabezado p {
            margin: 5px 0 0;
            color: #6b7c93;
        }

    .estado {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
    }

    .estado-programado {
        background: #fff3cd;
        color: #996c00;
    }

    .estado-juego {
        background: #d8efff;
        color: #00649b;
    }

    .estado-finalizado {
        background: #d8f3df;
        color: #157347;
    }

    .partido-card {
        background: white;
        border-radius: 14px;
        padding: 30px;
        box-shadow: 0 4px 18px rgba(16, 42, 67, 0.10);
        margin-bottom: 22px;
    }

    .numero-partido {
        text-align: center;
        color: #6b7c93;
        font-size: 14px;
        margin-bottom: 25px;
    }

    .equipos {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 30px;
    }

    .equipo {
        text-align: center;
    }

    .equipo-nombre {
        font-size: 23px;
        font-weight: 700;
        color: #102a43;
    }

    .grupo {
        margin-top: 7px;
        color: #6b7c93;
        font-size: 14px;
    }

    .marcador {
        min-width: 140px;
        text-align: center;
        font-size: 38px;
        font-weight: 800;
        color: #102a43;
    }

    .vs {
        text-align: center;
        font-size: 20px;
        font-weight: 700;
        color: #8795a1;
    }

    .informacion {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
        margin-top: 30px;
        padding-top: 25px;
        border-top: 1px solid #e4e9ef;
    }

    .dato {
        background: #f7f9fc;
        border-radius: 10px;
        padding: 16px;
    }

    .dato-titulo {
        display: block;
        color: #6b7c93;
        font-size: 13px;
        margin-bottom: 5px;
    }

    .dato-valor {
        color: #102a43;
        font-weight: 600;
    }

    .acciones-detalle {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }
</style>

<div class="detalle-contenedor">

    <div class="detalle-encabezado">
        <div>
            <h2>Detalle del partido</h2>
            <p>Información oficial del encuentro seleccionado.</p>
        </div>

        <span class="estado @claseEstado">
            @Model.Estado
        </span>
    </div>

    <div class="partido-card">

        <div class="numero-partido">
            Partido N.º @Model.NumeroPartidoFifa
        </div>

        <div class="equipos">

            <div class="equipo">
                <div class="equipo-nombre">
                    @Model.SeleccionLocal
                </div>

                <div class="grupo">
                    Selección local
                </div>
            </div>

            <div>
                @if (tieneMarcador)
                {
                    <div class="marcador">
                        @Model.GolesLocal - @Model.GolesVisitante
                    </div>
                }
                else
                {
                    <div class="vs">
                        VS
                    </div>
                }
            </div>

            <div class="equipo">
                <div class="equipo-nombre">
                    @Model.SeleccionVisitante
                </div>

                <div class="grupo">
                    Selección visitante
                </div>
            </div>

        </div>

        <div class="informacion">

            <div class="dato">
                <span class="dato-titulo">Fase</span>
                <span class="dato-valor">
                    @Model.Fase
                </span>
            </div>

            <div class="dato">
                <span class="dato-titulo">Grupo</span>
                <span class="dato-valor">
                    Grupo @Model.Grupo
                </span>
            </div>

            <div class="dato">
                <span class="dato-titulo">Fecha y hora</span>
                <span class="dato-valor">
                    @Model.FechaHora.ToString("dd/MM/yyyy HH:mm")
                </span>
            </div>

            <div class="dato">
                <span class="dato-titulo">Sede</span>
                <span class="dato-valor">
                    @Model.Sede
                </span>
            </div>

        </div>
    </div>

    <div class="acciones-detalle">

        <a asp-controller="Partidos"
           asp-action="Index"
           class="btn btn-outline-secondary">
            Volver al listado
        </a>

        <a asp-controller="Partidos"
           asp-action="RegistrarResultado"
           asp-route-id="@Model.Id"
           class="btn btn-success">
            Registrar resultado
        </a>

    </div>

</div>