@model FrontendAdministrativo.Models.ViewModels.ReporteEstadisticasViewModel

@{
    ViewData["Title"] = "Reportes";

    double porcentajeFinalizados =
        Model.TotalPartidos == 0
            ? 0
            : (double)Model.Finalizados /
              Model.TotalPartidos * 100;
}

<style>
    .reporte-encabezado {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
    }

        .reporte-encabezado h2 {
            margin: 0;
            color: #102a43;
            font-weight: 700;
        }

        .reporte-encabezado p {
            margin: 5px 0 0;
            color: #6b7c93;
        }

    .reporte-card {
        background: white;
        border-radius: 14px;
        padding: 20px;
        height: 100%;
        box-shadow: 0 4px 16px rgba(16, 42, 67, 0.08);
    }

        .reporte-card span {
            color: #6b7c93;
            font-size: 14px;
        }

        .reporte-card strong {
            display: block;
            margin-top: 8px;
            color: #102a43;
            font-size: 30px;
        }

        .reporte-card small {
            display: block;
            margin-top: 5px;
            color: #8795a1;
        }

    .reporte-destacado {
        border-left: 5px solid #f28c28;
    }

    .reporte-verde {
        border-left: 5px solid #198754;
    }

    .reporte-azul {
        border-left: 5px solid #0d6efd;
    }

    .reporte-rojo {
        border-left: 5px solid #dc3545;
    }

    .panel-reporte {
        background: white;
        border-radius: 14px;
        padding: 22px;
        box-shadow: 0 4px 16px rgba(16, 42, 67, 0.08);
        margin-top: 24px;
    }

        .panel-reporte h3 {
            margin: 0;
            color: #102a43;
            font-size: 20px;
            font-weight: 700;
        }

        .panel-reporte p {
            margin: 5px 0 20px;
            color: #6b7c93;
        }

    .partido-destacado {
        background: #f7f9fc;
        border-radius: 10px;
        padding: 18px;
    }

        .partido-destacado strong {
            color: #102a43;
            font-size: 18px;
        }

    .barra-progreso {
        height: 12px;
        background: #e9edf2;
        border-radius: 10px;
        overflow: hidden;
        margin-top: 10px;
    }

        .barra-progreso div {
            height: 100%;
            background: #198754;
            border-radius: 10px;
        }

    .estado-reporte {
        display: inline-block;
        padding: 7px 13px;
        border-radius: 20px;
        background: #d8f3df;
        color: #157347;
        font-size: 13px;
        font-weight: 700;
    }
</style>

<div class="reporte-encabezado">

    <div>
        <h2>Reportes del torneo</h2>
        <p>
            Resumen estadístico de los partidos y resultados registrados.
        </p>
    </div>

    @if (Model.ApiDisponible)
    {
        <span class="estado-reporte">
            Datos actualizados
        </span>
    }

</div>

@if (!Model.ApiDisponible)
{
    <div class="alert alert-warning">
        No fue posible conectarse con el Servicio de Estadísticas.
        Los reportes aparecerán cuando la API esté disponible.
    </div>
}
else
{
    <div class="row g-4">

        <div class="col-xl-3 col-md-6">
            <div class="reporte-card reporte-azul">
                <span>Total de partidos</span>
                <strong>@Model.TotalPartidos</strong>
                <small>Encuentros registrados</small>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="reporte-card reporte-verde">
                <span>Finalizados</span>
                <strong>@Model.Finalizados</strong>
                <small>Con marcador registrado</small>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="reporte-card reporte-destacado">
                <span>Total de goles</span>
                <strong>@Model.TotalGoles</strong>
                <small>Goles registrados en el torneo</small>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="reporte-card reporte-rojo">
                <span>Promedio de goles</span>
                <strong>
                    @Model.PromedioGoles.ToString("0.00")
                </strong>
                <small>Por partido finalizado</small>
            </div>
        </div>

    </div>

    <div class="panel-reporte">

        <h3>Progreso del torneo</h3>
        <p>
            Porcentaje de partidos que ya tienen un resultado registrado.
        </p>

        <strong>
            @porcentajeFinalizados.ToString("0.0")%
        </strong>

        <div class="barra-progreso">
            <div style="width: @porcentajeFinalizados.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)%;">
            </div>
        </div>

        <div class="mt-3 text-muted">
            Programados: @Model.Programados |
            En juego: @Model.EnJuego |
            Finalizados: @Model.Finalizados
        </div>

    </div>

    <div class="panel-reporte">

        <h3>Partido con más goles</h3>
        <p>
            Encuentro con la mayor cantidad de goles registrados.
        </p>

        <div class="partido-destacado">

            <strong>
                @Model.PartidoMasGoleador
            </strong>

            <div class="mt-2 text-muted">
                Total de goles:
                @Model.GolesPartidoMasGoleador
            </div>

        </div>

    </div>

    <div class="row g-4">

        <div class="col-lg-6">

            <div class="panel-reporte">

                <h3>Resumen por grupo</h3>
                <p>
                    Partidos, resultados y goles de cada grupo.
                </p>

                @if (Model.ResumenPorGrupo.Count == 0)
                {
                    <div class="alert alert-info">
                        No existen datos por grupo.
                    </div>
                }
                else
                {
                    <div class="table-responsive">

                        <table class="table admin-table align-middle">

                            <thead>
                                <tr>
                                    <th>Grupo</th>
                                    <th>Partidos</th>
                                    <th>Finalizados</th>
                                    <th>Goles</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var grupo in Model.ResumenPorGrupo)
                                {
                                    <tr>
                                        <td>
                                            <strong>
                                                Grupo @grupo.Grupo
                                            </strong>
                                        </td>

                                        <td>
                                            @grupo.Partidos
                                        </td>

                                        <td>
                                            @grupo.Finalizados
                                        </td>

                                        <td>
                                            @grupo.Goles
                                        </td>
                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>
                }

            </div>

        </div>

        <div class="col-lg-6">

            <div class="panel-reporte">

                <h3>Últimos resultados</h3>
                <p>
                    Diez resultados más recientes del torneo.
                </p>

                @if (Model.UltimosResultados.Count == 0)
                {
                    <div class="alert alert-info">
                        No existen resultados registrados.
                    </div>
                }
                else
                {
                    <div class="table-responsive">

                        <table class="table admin-table align-middle">

                            <thead>
                                <tr>
                                    <th>Partido</th>
                                    <th>Marcador</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var partido in Model.UltimosResultados)
                                {
                                    <tr>
                                        <td>
                                            <strong>
                                                @partido.SeleccionLocal
                                                vs.
                                                @partido.SeleccionVisitante
                                            </strong>

                                            <small class="d-block text-muted">
                                                @partido.Fase
                                            </small>
                                        </td>

                                        <td>
                                            <strong>
                                                @partido.GolesLocal -
                                                @partido.GolesVisitante
                                            </strong>
                                        </td>

                                        <td class="text-end">
                                            <a asp-controller="Partidos"
                                               asp-action="Detalles"
                                               asp-route-id="@partido.PartidoId"
                                               class="btn btn-sm btn-outline-primary">
                                                Ver
                                            </a>
                                        </td>
                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>
                }

            </div>

        </div>

    </div>
}