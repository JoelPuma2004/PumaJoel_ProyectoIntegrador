@model List<FrontendAdministrativo.Models.Api.SeleccionApiDto>

@{
    ViewData["Title"] = "Selecciones";

    List<string> grupos =
        ViewBag.Grupos as List<string>
        ?? new List<string>();

    string buscar =
        ViewBag.Buscar as string
        ?? string.Empty;

    string grupoSeleccionado =
        ViewBag.GrupoSeleccionado as string
        ?? string.Empty;

    int totalSelecciones =
        ViewBag.TotalSelecciones ?? 0;

    bool apiDisponible =
        ViewBag.ApiDisponible == true;
}

<style>
    .selecciones-contenedor {
        padding-bottom: 30px;
    }

    .selecciones-encabezado {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 22px;
    }

        .selecciones-encabezado h2 {
            margin: 0;
            color: #102a43;
            font-weight: 700;
        }

        .selecciones-encabezado p {
            margin: 5px 0 0;
            color: #6b7c93;
        }

    .contador-selecciones {
        background: #102a43;
        color: white;
        padding: 10px 18px;
        border-radius: 20px;
        font-weight: 700;
    }

    .filtros-selecciones {
        display: grid;
        grid-template-columns: 2fr 1fr auto auto;
        gap: 12px;
        padding: 18px;
        margin-bottom: 24px;
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 16px rgba(16, 42, 67, 0.08);
    }

    .grid-selecciones {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }

    .seleccion-card {
        background: white;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 4px 16px rgba(16, 42, 67, 0.08);
        border-left: 5px solid #102a43;
        transition: transform 0.2s ease;
    }

        .seleccion-card:hover {
            transform: translateY(-3px);
        }

    .seleccion-superior {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
    }

    .seleccion-nombre {
        color: #102a43;
        font-size: 18px;
        font-weight: 700;
    }

    .seleccion-codigo {
        display: inline-block;
        background: #eaf0f6;
        color: #102a43;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
    }

    .seleccion-grupo {
        margin-top: 18px;
        color: #6b7c93;
        font-size: 14px;
    }

        .seleccion-grupo strong {
            color: #102a43;
        }

    .sin-resultados {
        background: white;
        padding: 35px;
        border-radius: 14px;
        text-align: center;
        color: #6b7c93;
        box-shadow: 0 4px 16px rgba(16, 42, 67, 0.08);
    }

    @@media (max-width: 1000px) {
        .grid-selecciones {
            grid-template-columns: repeat(2, 1fr);
        }

        .filtros-selecciones {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 650px) {
        .grid-selecciones {
            grid-template-columns: 1fr;
        }

        .filtros-selecciones {
            grid-template-columns: 1fr;
        }

        .selecciones-encabezado {
            align-items: flex-start;
            flex-direction: column;
        }
    }
    .seleccion-identidad {
    display: flex;
    align-items: center;
    gap: 11px;
}

.bandera-seleccion {
    width: 38px;
    height: 27px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid #d7dee7;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.16);
    flex-shrink: 0;
}
</style>

<div class="selecciones-contenedor">

    <div class="selecciones-encabezado">
        <div>
            <h2>Selecciones participantes</h2>
            <p>
                Consulta las selecciones registradas para el Mundial 2026.
            </p>
        </div>

        <div class="contador-selecciones">
            Total: @totalSelecciones
        </div>
    </div>

    @if (!apiDisponible)
    {
        <div class="alert alert-warning">
            No fue posible conectarse con el Servicio de Estadísticas.
            Las selecciones aparecerán cuando la API esté disponible.
        </div>
    }
    else
    {
        <div class="alert alert-success">
            Selecciones cargadas desde el Servicio de Estadísticas.
        </div>
    }

    <form asp-controller="Selecciones"
          asp-action="Index"
          method="get"
          class="filtros-selecciones">

        <input type="text"
               name="buscar"
               value="@buscar"
               class="form-control"
               placeholder="Buscar por nombre o código..." />

        <select name="grupo"
                class="form-select">

            <option value="">Todos los grupos</option>

            @foreach (string grupo in grupos)
            {
                if (grupo == grupoSeleccionado)
                {
                    <option value="@grupo" selected>
                        Grupo @grupo
                    </option>
                }
                else
                {
                    <option value="@grupo">
                        Grupo @grupo
                    </option>
                }
            }
        </select>

        <button type="submit"
                class="btn btn-primary">
            Filtrar
        </button>

        <a asp-controller="Selecciones"
           asp-action="Index"
           class="btn btn-outline-secondary">
            Limpiar
        </a>

    </form>

    @if (Model.Count == 0)
    {
        <div class="sin-resultados">
            No se encontraron selecciones.
        </div>
    }
    else
    {
        <div class="grid-selecciones">

            @foreach (var seleccion in Model)
            {
                string grupoNormalizado =
                    seleccion.Grupo
                        .Replace(
                            "GRUPO_",
                            string.Empty,
                            StringComparison.OrdinalIgnoreCase)
                        .Replace(
                            "Grupo",
                            string.Empty,
                            StringComparison.OrdinalIgnoreCase)
                        .Trim()
                        .ToUpperInvariant();

                <div class="seleccion-card">

                    <div class="seleccion-superior">

                        <div class="seleccion-identidad">

                            @if (!string.IsNullOrWhiteSpace(
                                seleccion.CodigoBandera))
                            {
                                <img src="https://flagcdn.com/@(seleccion.CodigoBandera).svg"
                                     alt="Bandera de @seleccion.Nombre"
                                     class="bandera-seleccion"
                                     loading="lazy"
                                     onerror="this.style.display='none'" />
                            }

                            <div class="seleccion-nombre">
                                @seleccion.Nombre
                            </div>

                        </div>

                        <span class="seleccion-codigo">
                            @seleccion.CodigoPais
                        </span>

                    </div>

                    <div class="seleccion-grupo">
                        Grupo:
                        <strong>
                            @grupoNormalizado
                        </strong>
                    </div>

                </div>
            }

        </div>
    }

</div>