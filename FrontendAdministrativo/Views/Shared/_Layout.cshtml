<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - UTN GolMundial 2026</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <div class="admin-container">

        <!-- Menú lateral -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>UTN GolMundial</h2>
                <span>Panel administrativo</span>
            </div>

            <nav class="sidebar-menu">
                <a asp-controller="Home" asp-action="Index">
                    Dashboard
                </a>

                <a asp-controller="Selecciones" asp-action="Index">
                    Selecciones
                </a>

                <a asp-controller="Partidos" asp-action="Index">
                    Partidos
                </a>

                <a asp-controller="Resultados" asp-action="Index">
                    Registrar resultados
                </a>

                <a asp-controller="Usuarios" asp-action="Index">
                    Usuarios
                </a>

                <a asp-controller="Reportes" asp-action="Index">
                    Reportes
                </a>

                <a asp-controller="EstadoServicios" asp-action="Index">
                    Estado de servicios
                </a>
            </nav>

            <div class="sidebar-footer">
                <span>Mundial 2026</span>
                <small>UTNGolCoin</small>
            </div>
        </aside>

        <!-- Contenido principal -->
        <main class="main-content">

            <header class="topbar">
                <div>
                    <h1>@ViewData["Title"]</h1>
                    <p>Administración de la plataforma</p>
                </div>

                <div class="admin-info">

                    <span>
                        @(User.Identity?.Name ?? "Administrador")
                    </span>

                    <form asp-controller="Auth"
                          asp-action="Logout"
                          method="post"
                          class="m-0">

                        @Html.AntiForgeryToken()

                        <button type="submit"
                                class="btn btn-outline-danger btn-sm">
                            Cerrar sesión
                        </button>

                    </form>

                </div>
            </header>

            <section class="content-area">
                @RenderBody()
            </section>

            <footer class="admin-footer">
                UTN GolMundial 2026 — Universidad Técnica del Norte
            </footer>
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>