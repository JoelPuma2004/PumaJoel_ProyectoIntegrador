@model FrontendAdministrativo.Models.ViewModels.UTNGolCoinViewModel

@{
    ViewData["Title"] = "UTNGolCoin";
}

<style>
    .coin-header h2 {
        margin: 0;
        color: #102a43;
        font-weight: 700;
    }

    .coin-header p {
        margin-top: 6px;
        color: #6b7c93;
    }

    .coin-metric {
        background: white;
        padding: 20px;
        border-radius: 13px;
        border-left: 5px solid #f59e0b;
        box-shadow: 0 4px 16px rgba(16, 42, 67, 0.08);
        height: 100%;
    }

        .coin-metric span {
            display: block;
            color: #6b7c93;
            font-size: 14px;
        }

        .coin-metric strong {
            display: block;
            margin-top: 8px;
            color: #102a43;
            font-size: 25px;
        }

        .coin-metric small {
            display: block;
            margin-top: 7px;
        }

    .coin-panel {
        background: white;
        padding: 25px;
        border-radius: 14px;
        box-shadow: 0 4px 18px rgba(16, 42, 67, 0.08);
    }

    .coin-status {
        padding: 15px;
        border-radius: 10px;
        background: #f7f9fc;
    }

    .coin-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 22px;
    }
</style>

<div class="coin-header mb-4">
    <h2>Configuración UTNGolCoin</h2>

    <p>
        Consulta el estado de las billeteras y administra
        parámetros temporales de monedas y apuestas.
    </p>
</div>

@if (Model.ServicioDisponible)
{
    <div class="alert alert-success">
        Conectado correctamente con la API UTNGolCoin de Mayra.
        Las monedas en circulación y las billeteras son datos reales.
    </div>
}
else
{
    <div class="alert alert-danger">
        No fue posible conectarse con la API UTNGolCoin.
        Revisa que Mayra tenga el servicio encendido y que ambos
        equipos estén conectados a la misma red.
    </div>
}

@if (Model.ConfiguracionDisponible)
{
    <div class="alert alert-success">
        La configuración de apuestas está conectada
        con la API real de Mayra.
    </div>
}
else
{
    <div class="alert alert-warning">
        No fue posible obtener la configuración real
        de UTNGolCoin.
    </div>
}

@if (TempData["MensajeExito"] is string mensaje)
{
    <div class="alert alert-success alert-dismissible fade show"
         role="alert">

        @mensaje

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Cerrar">
        </button>
    </div>
}

<div class="row g-3 mb-4">

    <div class="col-lg-4">
        <div class="coin-metric">
            <span>Monedas en circulación</span>

            <strong>
                @Model.MonedasEnCirculacion.ToString("N0")
            </strong>

            <small class="text-muted">
                Suma de los saldos obtenidos del ranking real.
            </small>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="coin-metric">
            <span>Billeteras registradas</span>

            <strong>
                @Model.TotalBilleteras
            </strong>

            <small class="text-muted">
                Usuarios encontrados en la API UTNGolCoin.
            </small>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="coin-metric">
            <span>Estado del servicio</span>

            @if (Model.ServicioDisponible)
            {
                <strong class="text-success"
                        style="font-size: 18px;">
                    Conectado
                </strong>

                <small class="text-muted">
                    La API respondió correctamente.
                </small>
            }
            else
            {
                <strong class="text-danger"
                        style="font-size: 18px;">
                    Desconectado
                </strong>

                <small class="text-muted">
                    No se pudo consultar el ranking.
                </small>
            }
        </div>
    </div>

</div>

@if (Model.ServicioDisponible && Model.Ranking.Count > 0)
{
    <div class="coin-panel mb-4">

        <h4 class="mb-3">
            Ranking de billeteras
        </h4>

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead>
                    <tr>
                        <th>Posición</th>
                        <th>Usuario</th>
                        <th class="text-end">Saldo</th>
                    </tr>
                </thead>

                <tbody>

                    @{
                        int posicion = 1;
                    }

                    @foreach (var usuario in Model.Ranking)
                    {
                        <tr>
                            <td>
                                <strong>
                                    #@posicion
                                </strong>
                            </td>

                            <td>
                                Usuario @usuario.UsuarioId
                            </td>

                            <td class="text-end">
                                <strong>
                                    @usuario.Saldo.ToString("N0")
                                    UTNGolCoin
                                </strong>
                            </td>
                        </tr>

                        posicion++;
                    }

                </tbody>

            </table>

        </div>

    </div>
}
else if (Model.ServicioDisponible)
{
    <div class="alert alert-info">
        La API está conectada, pero todavía no existen billeteras
        registradas en el ranking.
    </div>
}

<div class="coin-panel">

    <h4 class="mb-3">
        Parámetros de apuestas
    </h4>

    <form asp-controller="UTNGolCoin"
          asp-action="Guardar"
          method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="row g-3">

            <div class="col-lg-4">

                <label asp-for="BonoInicial"
                       class="form-label">
                </label>

                <input asp-for="BonoInicial"
                       class="form-control"
                       type="number"
                       step="0.01"
                       min="0" />


                <span asp-validation-for="BonoInicial"
                      class="text-danger">
                </span>

                <small class="text-muted">
                    Monedas entregadas al crear una cuenta.
                </small>

            </div>

            <div class="col-lg-4">

                <label asp-for="MonedasPorAcierto"
                       class="form-label">
                </label>

                <input asp-for="MonedasPorAcierto"
                       class="form-control"
                       type="number"
                       step="0.01"
                       min="1" />

                <span asp-validation-for="MonedasPorAcierto"
                      class="text-danger">
                </span>

                <small class="text-muted">
                    Recompensa base por acertar un resultado.
                </small>

            </div>

            <div class="col-lg-4">

                <label asp-for="LimiteMaximoApuesta"
                       class="form-label">
                </label>

                <input asp-for="LimiteMaximoApuesta"
                       class="form-control"
                       type="number"
                       step="0.01"
                       min="1" />

                <span asp-validation-for="LimiteMaximoApuesta"
                      class="text-danger">
                </span>

                <small class="text-muted">
                    Máximo de monedas permitidas por apuesta.
                </small>

            </div>

        </div>

        <div class="coin-status mt-4">

            <div class="form-check form-switch">

                <input asp-for="ApuestasHabilitadas"
                       class="form-check-input"
                       type="checkbox"
                       role="switch" />

                <label asp-for="ApuestasHabilitadas"
                       class="form-check-label">
                </label>

            </div>

            <small class="text-muted">
                Los cambios se guardarán en la API real de UTNGolCoin.
            </small>

        </div>

        <div class="coin-actions">

            <button type="submit"
                    class="btn btn-primary">
                Guardar configuración
            </button>

        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}