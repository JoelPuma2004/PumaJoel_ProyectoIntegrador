@model FrontendAdministrativo.Models.ViewModels.UsuariosIndexViewModel

@{
    ViewData["Title"] = "Usuarios";
}

<style>
    .usuarios-encabezado {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 22px;
    }

        .usuarios-encabezado h2 {
            margin: 0;
            color: #102a43;
            font-weight: 700;
        }

        .usuarios-encabezado p {
            margin: 5px 0 0;
            color: #6b7c93;
        }

    .usuario-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .usuario-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #102a43;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex-shrink: 0;
    }

    .usuario-nombre {
        color: #102a43;
        font-weight: 700;
    }

    .usuario-correo {
        color: #6b7c93;
        font-size: 13px;
    }

    .rol-badge,
    .estado-badge {
        display: inline-block;
        padding: 6px 11px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
    }

    .rol-administrador {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .rol-usuario {
        background: #e9ecef;
        color: #495057;
    }

    .estado-activo {
        background: #d8f3df;
        color: #157347;
    }

    .estado-inactivo {
        background: #f8d7da;
        color: #b02a37;
    }
</style>

<div class="usuarios-encabezado">
    <div>
        <h2>Usuarios y roles</h2>
        <p>
            Consulta usuarios, modifica roles y administra su estado.
        </p>
    </div>
</div>

@if (TempData["MensajeExito"] is string mensaje)
{
    <div class="alert alert-success alert-dismissible fade show">
        @mensaje

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}
@if (TempData["MensajeError"] is string mensajeError)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @mensajeError

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

<div class="row g-3 mb-4">

    <div class="col-lg-4 col-md-6">
        <div class="summary-card">
            <span>Total de usuarios</span>
            <strong>@Model.TotalUsuarios</strong>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="summary-card finished">
            <span>Usuarios activos</span>
            <strong>@Model.UsuariosActivos</strong>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="summary-card live">
            <span>Administradores</span>
            <strong>@Model.Administradores</strong>
        </div>
    </div>

</div>

<div class="panel-card mb-4">

    <form asp-controller="Usuarios"
          asp-action="Index"
          method="get">

        <div class="row g-3 align-items-end">

            <div class="col-lg-4">
                <label class="form-label">
                    Buscar
                </label>

                <input type="text"
                       name="buscar"
                       value="@Model.Buscar"
                       class="form-control"
                       placeholder="Nombre o correo..." />
            </div>

            <div class="col-lg-3">
                <label class="form-label">
                    Rol
                </label>

                <select name="rol"
                        class="form-select">

                    <option value="">
                        Todos los roles
                    </option>

                    @if (Model.RolSeleccionado == "ADMINISTRADOR")
                    {
                        <option value="ADMINISTRADOR" selected>
                            Administrador
                        </option>
                    }
                    else
                    {
                        <option value="ADMINISTRADOR">
                            Administrador
                        </option>
                    }

                    @if (Model.RolSeleccionado == "USUARIO")
                    {
                        <option value="USUARIO" selected>
                            Usuario
                        </option>
                    }
                    else
                    {
                        <option value="USUARIO">
                            Usuario
                        </option>
                    }

                </select>
            </div>

            <div class="col-lg-3">
                <label class="form-label">
                    Estado
                </label>

                <select name="estado"
                        class="form-select">

                    <option value="">
                        Todos los estados
                    </option>

                    @if (Model.EstadoSeleccionado == "ACTIVO")
                    {
                        <option value="ACTIVO" selected>
                            Activo
                        </option>
                    }
                    else
                    {
                        <option value="ACTIVO">
                            Activo
                        </option>
                    }

                    @if (Model.EstadoSeleccionado == "INACTIVO")
                    {
                        <option value="INACTIVO" selected>
                            Inactivo
                        </option>
                    }
                    else
                    {
                        <option value="INACTIVO">
                            Inactivo
                        </option>
                    }

                </select>
            </div>

            <div class="col-lg-2">
                <button type="submit"
                        class="btn btn-primary">
                    Filtrar
                </button>

                <a asp-controller="Usuarios"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>

        </div>

    </form>

</div>

<div class="panel-card">

    <div class="panel-card-header">
        <div>
            <h3>Usuarios registrados</h3>
            <p>
                @Model.Usuarios.Count usuario(s) encontrado(s)
            </p>
        </div>
    </div>

    @if (Model.Usuarios.Count == 0)
    {
        <div class="empty-state">
            <h4>No se encontraron usuarios</h4>
            <p>
                Cambia los filtros para consultar otros registros.
            </p>
        </div>
    }
    else
    {
        <div class="table-responsive">

            <table class="table admin-table align-middle">

                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Registro</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var usuario in Model.Usuarios)
                    {
                        string inicial =
                            string.IsNullOrWhiteSpace(
                                usuario.NombreCompleto)
                                ? "U"
                                : usuario.NombreCompleto
                                    .Substring(0, 1)
                                    .ToUpperInvariant();

                        <tr>

                            <td>
                                <div class="usuario-info">

                                    <div class="usuario-avatar">
                                        @inicial
                                    </div>

                                    <div>
                                        <div class="usuario-nombre">
                                            @usuario.NombreCompleto
                                        </div>

                                        <div class="usuario-correo">
                                            @usuario.Correo
                                        </div>
                                    </div>

                                </div>
                            </td>

                            <td>
                                @if (usuario.Rol == "ADMINISTRADOR")
                                {
                                    <span class="rol-badge rol-administrador">
                                        Administrador
                                    </span>
                                }
                                else
                                {
                                    <span class="rol-badge rol-usuario">
                                        Usuario
                                    </span>
                                }
                            </td>

                            <td>
                                @if (usuario.Activo)
                                {
                                    <span class="estado-badge estado-activo">
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="estado-badge estado-inactivo">
                                        Inactivo
                                    </span>
                                }
                            </td>

                            <td>
                                @if (usuario.FechaRegistro == DateTime.MinValue)
                                {
                                    <span class="text-muted">
                                        No disponible
                                    </span>
                                }
                                else
                                {
                                    @usuario.FechaRegistro.ToString("dd/MM/yyyy HH:mm")
                                }
                            </td>

                            <td class="text-end">

                                <a asp-controller="Usuarios"
                                   asp-action="Editar"
                                   asp-route-id="@usuario.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Editar
                                </a>

                                <form asp-controller="Usuarios"
                                      asp-action="CambiarEstado"
                                      asp-route-id="@usuario.Id"
                                      method="post"
                                      class="d-inline">

                                    @Html.AntiForgeryToken()

                                    @if (usuario.Activo)
                                    {
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger">
                                            Desactivar
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-success">
                                            Activar
                                        </button>
                                    }

                                </form>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

</div>